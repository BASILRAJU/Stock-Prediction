# Virtual environment
venv/

# Environment variables - NEVER commit
.env

# Data files
data/raw/
data/cache/
data/charts/

# INCLUDE trained models AND processed features in git
!data/models/
!data/models/**
!data/processed/
!data/processed/**

# Log files
logs/

# Python cache - never needed on GitHub
__pycache__/
*.pyc
*.pyo
*.pyd

# Parquet files (but include processed features)
*.parquet
!data/processed/*.parquet

# VS Code
.vscode/

# Windows
Thumbs.db
desktop.ini
# Chart caches — regenerated locally, too big for git
data/charts/
data/charts_annotated/
